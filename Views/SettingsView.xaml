<UserControl
    x:Class="Quotix.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:conv="clr-namespace:Quotix.Converters"
    xmlns:local="clr-namespace:Quotix"
    Background="Transparent"
    Height="720">

    <UserControl.Resources>
        <BitmapImage x:Key="AppIcon" UriSource="pack://application:,,,/Resources/app.ico"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBoolToVis"/>
        <conv:CategoryToVisibilityConverter x:Key="CategoryToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ====== 左侧导航栏 ====== -->
        <Border Grid.Column="0"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
            <ListBox ItemsSource="{Binding SettingsCategories}"
                     SelectedValue="{Binding SelectedSettingsCategory, Mode=TwoWay}"
                     SelectedValuePath="Key"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="10,14"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="MinHeight" Value="40"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" CornerRadius="8"
                                            Background="Transparent"
                                            Margin="8,0,8,0"
                                            VerticalAlignment="Stretch"
                                            Padding="12,0">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- 选中态：accent 背景 + 反色文字，无指示条 -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                                        </Trigger>
                                        <!-- 仅未选中时悬停才显示淡背景，避免覆盖选中高亮 -->
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ui:TextBlock Text="{Binding Label}" FontSize="13"
                                          VerticalAlignment="Center"
                                          Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- ====== 右侧内容区 ====== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      Padding="24,20,24,24">
            <StackPanel>

                <!-- ====== 导出路径 ====== -->
                <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=export}">
                    <Border CornerRadius="10"
                            Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                <ui:SymbolIcon Symbol="FolderOpen16" FontSize="18"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <ui:TextBlock Text="默认导出位置" FontSize="14" FontWeight="Medium"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <ui:TextBlock Text="{Binding DefaultExportPath}" FontSize="11"
                                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                              Margin="0,2,0,0"
                                              TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <ui:Button Grid.Column="2" Content="打开文件夹" Appearance="Secondary"
                                       Height="34" FontSize="12"
                                       Command="{Binding OpenExportFolderCommand}"
                                       Margin="0,0,8,0"/>

                            <ui:Button Grid.Column="3" Content="修改" Appearance="Primary"
                                       Height="34" FontSize="12"
                                       Command="{Binding BrowseExportPathCommand}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ====== 快捷输入 ====== -->
                <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=quickinput}">
                    <Border CornerRadius="10"
                            Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <ui:SymbolIcon Symbol="Search16" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <ui:TextBlock Text="启用快捷输入" FontSize="14" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <ui:TextBlock Text="关闭后，报价单编号列不再触发产品快速搜索"
                                                  FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                  Margin="0,2,0,0"/>
                                </StackPanel>

                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding QuickInputEnabled}"
                                                 VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <ui:SymbolIcon Symbol="Search16" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <ui:TextBlock Text="模糊搜索" FontSize="14" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <ui:TextBlock Text="在所有快捷搜索框与弹窗启用模糊匹配（支持字符分散匹配，如 1-3 匹配 1-2-3）"
                                                  FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                  Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding QuickInputFuzzyEnabled}"
                                                 VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource CardStrokeColorDefaultBrush}"
                                       Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" Text="编辑数据库" FontSize="13"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ui:Button Content="NDT" MinWidth="56" Height="32" FontSize="13"
                                               Appearance="{Binding QuickInputDb, Converter={StaticResource QuickDbAppearance}, ConverterParameter=NDT}"
                                               Command="{Binding SwitchQuickInputDbCommand}" CommandParameter="NDT"/>
                                    <ui:Button Content="RVI" MinWidth="56" Height="32" FontSize="13" Margin="6,0,0,0"
                                               Appearance="{Binding QuickInputDb, Converter={StaticResource QuickDbAppearance}, ConverterParameter=RVI}"
                                               Command="{Binding SwitchQuickInputDbCommand}" CommandParameter="RVI"/>
                                </StackPanel>
                            </Grid>

                            <ui:TextBlock Text="为每个报价单输入框选择对应的数据表列（留空表示不填充）："
                                          FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                          Margin="0,0,0,8"/>

                            <ItemsControl ItemsSource="{Binding QuickInputRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBlock Grid.Column="0" Text="{Binding TargetLabel}" FontSize="13"
                                                          VerticalAlignment="Center"
                                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.QuickInputColumnOptions}"
                                                      DisplayMemberPath="Display" SelectedValuePath="Value"
                                                      SelectedValue="{Binding SelectedColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Height="32" FontSize="12" HorizontalAlignment="Stretch"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Rectangle Height="1" Fill="{DynamicResource CardStrokeColorDefaultBrush}"
                                       Margin="10,4,0,10"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ui:Button Content="清空映射" Appearance="Secondary" Height="32" FontSize="12"
                                           Command="{Binding ClearMappingCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====== 外观 ====== -->
                <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=appearance}">
                    <Border CornerRadius="10"
                            Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                <Grid>
                                    <ui:SymbolIcon Symbol="WeatherMoon16" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding IsDarkMode, Converter={StaticResource BoolToVis}}"/>
                                    <ui:SymbolIcon Symbol="WeatherSunny16" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding IsDarkMode, Converter={StaticResource InverseBoolToVis}}"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <ui:TextBlock Text="深色模式" FontSize="14" FontWeight="Medium"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <ui:TextBlock Text="降低屏幕亮度，减轻眼睛疲劳" FontSize="12"
                                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                              Margin="0,2,0,0"/>
                            </StackPanel>

                            <ui:ToggleSwitch Grid.Column="2"
                                             IsChecked="{Binding IsDarkMode}"
                                             VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ====== 产品列表 ====== -->
                <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=products}">
                    <Border CornerRadius="10"
                            Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ui:TextBlock Grid.Column="0" Text="目标产品列表" FontSize="13"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                              VerticalAlignment="Center" Margin="0,0,12,0"/>

                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding DatabaseOptions}"
                                          SelectedItem="{Binding SelectedDatabase}"
                                          DisplayMemberPath="Label"
                                          Height="32" FontSize="12"
                                          VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource CardStrokeColorDefaultBrush}"
                                       Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <ui:SymbolIcon Symbol="ArrowDownload16" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <ui:TextBlock Text="导入数据" FontSize="14" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <ui:TextBlock Text="从 Excel 文件导入产品数据" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                  Margin="0,2,0,0"/>
                                </StackPanel>

                                <ui:Button Grid.Column="2" Content="导入 Excel" Appearance="Primary"
                                           Height="34" FontSize="12"
                                           Command="{Binding ImportDataCommand}"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{DynamicResource CardStrokeColorDefaultBrush}"
                                       Margin="0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <ui:SymbolIcon Symbol="Delete16" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <ui:TextBlock Text="清除数据" FontSize="14" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <ui:TextBlock Text="删除选中产品列表的全部内容" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                  Margin="0,2,0,0"/>
                                </StackPanel>

                                <ui:Button Grid.Column="2" Content="清除数据" Appearance="Danger"
                                           Height="34" FontSize="12"
                                           Command="{Binding ClearDataCommand}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="10"
                            Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14" Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                <ui:SymbolIcon Symbol="Delete16" FontSize="18"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <ui:TextBlock Text="清理无效记录" FontSize="14" FontWeight="Medium"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <ui:TextBlock Text="删除 TableName 为空或数据无效的孤儿条目" FontSize="12"
                                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                              Margin="0,2,0,0"/>
                            </StackPanel>

                            <ui:Button Grid.Column="2" Content="立即清理" Appearance="Danger"
                                       Height="34" FontSize="12"
                                       Command="{Binding CleanOrphansCommand}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ====== 问题反馈 ====== -->
                <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=feedback}">
                    <Border CornerRadius="10"
                            Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <ui:SymbolIcon Symbol="Chat16" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <ui:TextBlock Text="问题反馈" FontSize="14" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <ui:TextBlock Text="反馈需要连接网络，截图和错误日志只在选择时附加上传"
                                                  FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                  Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <ui:TextBlock Text="问题类型" FontSize="13" FontWeight="Medium"
                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                          Margin="0,0,0,10"/>

                            <WrapPanel Margin="0,0,0,18">
                                <RadioButton Content="程序崩溃" GroupName="FeedbackType"
                                             IsChecked="{Binding IsFeedbackCrash, Mode=OneWay}"
                                             Command="{Binding SetFeedbackProblemTypeCommand}"
                                             CommandParameter="程序崩溃"
                                             Margin="0,0,22,8"/>
                                <RadioButton Content="功能异常" GroupName="FeedbackType"
                                             IsChecked="{Binding IsFeedbackFunctionError, Mode=OneWay}"
                                             Command="{Binding SetFeedbackProblemTypeCommand}"
                                             CommandParameter="功能异常"
                                             Margin="0,0,22,8"/>
                                <RadioButton Content="数据错误" GroupName="FeedbackType"
                                             IsChecked="{Binding IsFeedbackDataError, Mode=OneWay}"
                                             Command="{Binding SetFeedbackProblemTypeCommand}"
                                             CommandParameter="数据错误"
                                             Margin="0,0,22,8"/>
                                <RadioButton Content="功能建议" GroupName="FeedbackType"
                                             IsChecked="{Binding IsFeedbackSuggestion, Mode=OneWay}"
                                             Command="{Binding SetFeedbackProblemTypeCommand}"
                                             CommandParameter="功能建议"
                                             Margin="0,0,22,8"/>
                            </WrapPanel>

                            <ui:TextBlock Text="问题描述" FontSize="13" FontWeight="Medium"
                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                          Margin="0,0,0,8"/>
                            <ui:TextBox Text="{Binding FeedbackDescription, UpdateSourceTrigger=PropertyChanged}"
                                        Height="132"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        VerticalContentAlignment="Top"
                                        PlaceholderText="请描述你遇到的问题、触发步骤或建议内容"
                                        Margin="0,0,0,18"/>

                            <ui:TextBlock Text="截图" FontSize="13" FontWeight="Medium"
                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                          Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ui:Button Grid.Column="0" Content="添加图片" Appearance="Secondary"
                                           Height="34" FontSize="12"
                                           Command="{Binding SelectFeedbackScreenshotCommand}"/>

                                <ui:TextBlock Grid.Column="1" Text="{Binding FeedbackScreenshotName}"
                                              FontSize="12" VerticalAlignment="Center"
                                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                              TextTrimming="CharacterEllipsis"
                                              Margin="12,0"/>

                                <ui:Button Grid.Column="2" Content="移除" Appearance="Secondary"
                                           Height="34" FontSize="12"
                                           Command="{Binding ClearFeedbackScreenshotCommand}"/>
                            </Grid>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0"
                                          Content="自动附加错误日志（如果存在）"
                                          IsChecked="{Binding FeedbackAttachErrorLog}"
                                          VerticalAlignment="Center"/>

                                <ui:TextBlock Grid.Column="1" Text="{Binding FeedbackErrorLogStatus}"
                                              FontSize="12" VerticalAlignment="Center"
                                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                              HorizontalAlignment="Right"/>
                            </Grid>

                            <ui:Button Content="发送反馈" Appearance="Primary"
                                       Height="36" MinWidth="112" FontSize="13"
                                       HorizontalAlignment="Right"
                                       Command="{Binding SendFeedbackCommand}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====== 关于 ====== -->
                <StackPanel Visibility="{Binding SelectedSettingsCategory, Converter={StaticResource CategoryToVisibility}, ConverterParameter=about}">
                    <Border CornerRadius="10"
                            Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="20,18">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image Grid.Column="0" Width="40" Height="40"
                                       Source="{StaticResource AppIcon}"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       VerticalAlignment="Center" Margin="0,0,14,0"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="Quotix" FontSize="16"
                                                      FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <Border Grid.Column="1" CornerRadius="4" Padding="5,1" Margin="8,0,0,0"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                VerticalAlignment="Center">
                                            <ui:TextBlock Text="{Binding AppVersion}" FontSize="10" FontWeight="SemiBold"
                                                          Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <WrapPanel Margin="0,0,0,12">
                                <Border CornerRadius="4" Padding="8,3" Margin="0,0,6,0"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <ui:TextBlock Text=".NET 10" FontSize="11"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                                <Border CornerRadius="4" Padding="8,3" Margin="0,0,6,0"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <ui:TextBlock Text="WPF UI Fluent" FontSize="11"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                                <Border CornerRadius="4" Padding="8,3" Margin="0,0,6,0"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <ui:TextBlock Text="SQLite" FontSize="11"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                                <Border CornerRadius="4" Padding="8,3"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <ui:TextBlock Text="MVVM" FontSize="11"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="10" Margin="0,12,0,0"
                            Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="8" Width="40" Height="40"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                <ui:SymbolIcon Symbol="ArrowSync16" FontSize="18"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <ui:TextBlock Text="检查更新" FontSize="14" FontWeight="Medium"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <ui:TextBlock Text="{Binding UpdateStatusText}" FontSize="12"
                                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                              Margin="0,2,0,0"/>
                            </StackPanel>

                            <ui:Button Grid.Column="2" Content="检查更新"
                                       Appearance="Primary"
                                       Height="34" FontSize="12"
                                       Command="{Binding CheckUpdateCommand}"/>
                        </Grid>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
