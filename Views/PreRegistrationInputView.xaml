<UserControl x:Class="Quotix.Views.PreRegistrationInputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="CompactCard" TargetType="Border" BasedOn="{StaticResource SectionCard}">
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="ui:TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="ui:TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}"/>
        </Style>

        <Style x:Key="AreaBox" TargetType="TextBox" BasedOn="{StaticResource FieldBox}">
            <Setter Property="Height" Value="116"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20,24,24">
        <Border Style="{StaticResource AppCardModern}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <ui:TextBlock Text="NDT 预报备填入" FontSize="22" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ui:TextBlock Text="布局按原模板顺序排列，导出时生成原格式 Excel"
                                      FontSize="12"
                                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                      Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Content="重置" Appearance="Secondary" Height="34" MinWidth="82"
                                   Command="{Binding ResetCommand}"/>
                        <ui:Button Content="保存" Appearance="Secondary" Height="34" MinWidth="82" Margin="8,0,0,0"
                                   Command="{Binding SaveCommand}"/>
                        <ui:Button Content="保存并导出" Appearance="Primary" Height="34" MinWidth="112" Margin="8,0,0,0"
                                   Command="{Binding SaveAndExportCommand}"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel MaxWidth="1080" HorizontalAlignment="Center">
                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <ui:TextBlock Text="代理商" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1.4*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                                        <ui:TextBlock Text="名称" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding AgentName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,12">
                                        <ui:TextBlock Text="报备日期" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding RegistrationDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,12,12">
                                        <ui:TextBlock Text="销售担当" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding AgentSales, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,12">
                                        <ui:TextBlock Text="手机" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding AgentPhone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4">
                                        <ui:TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding AgentEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <ui:TextBlock Text="中间商" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="1.8*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                                        <ui:TextBlock Text="名称" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding MiddlemanName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,12">
                                        <ui:TextBlock Text="地址" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding MiddlemanAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,12,12">
                                        <ui:TextBlock Text="销售担当" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding MiddlemanSales, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,12">
                                        <ui:TextBlock Text="手机" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding MiddlemanPhone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4">
                                        <ui:TextBlock Text="邮箱" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding MiddlemanEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <ui:TextBlock Text="客户基本信息" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                        <StackPanel Margin="0,0,0,12">
                                            <ui:TextBlock Text="客户名称" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <ui:TextBlock Text="地址" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CustomerAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <ui:TextBlock Text="部门" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CustomerDepartment, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <ui:TextBlock Text="联络人" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CustomerContact, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <ui:TextBlock Text="行业市场" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding IndustryMarket, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                        <StackPanel Margin="0,0,0,12">
                                            <ui:TextBlock Text="电话" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CustomerTel, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <ui:TextBlock Text="传真" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CustomerFax, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <ui:TextBlock Text="电邮" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CustomerEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <ui:TextBlock Text="手机" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding CustomerMobile, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <ui:TextBlock Text="信息来源" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding InformationSource, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <ui:TextBlock Text="应用信息及目的" Style="{StaticResource SectionTitle}"/>
                                <TextBox Text="{Binding ApplicationPurpose, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AreaBox}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <ui:TextBlock Text="推荐产品&amp;数量" Style="{StaticResource SectionTitle}"/>
                                <TextBox Text="{Binding RecommendedProducts, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AreaBox}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <ui:TextBlock Text="客户及竞争对手信息" Style="{StaticResource SectionTitle}"/>
                                <TextBox Text="{Binding CompetitorInfo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AreaBox}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <ui:TextBlock Text="推进节点活动和结果" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="136"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding ActivityDate1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" Margin="0,0,10,10"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ActivityContent1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding ActivityDate2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" Margin="0,0,10,10"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ActivityContent2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="2" Grid.Column="0" Text="{Binding ActivityDate3, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" Margin="0,0,10,10"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ActivityContent3, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding ActivityDate4, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" Margin="0,0,10,10"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ActivityContent4, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="4" Grid.Column="0" Text="{Binding ActivityDate5, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" Margin="0,0,10,10"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ActivityContent5, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="5" Grid.Column="0" Text="{Binding ActivityDate6, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}" Margin="0,0,10,0"/>
                                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ActivityContent6, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <ui:TextBlock Text="案件结果" Style="{StaticResource SectionTitle}"/>
                                <TextBox Text="{Binding CaseResult, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AreaBox}" Height="76"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
