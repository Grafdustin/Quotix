<UserControl x:Class="Quotix.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,16"/>
        </Style>

        <Style x:Key="SectionSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="QuoteRowContainer" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20,24,24">
        <Border Style="{StaticResource AppCardModern}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <ui:TextBlock Text="首页" FontSize="22" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:TextBlock Text="{Binding LastUpdatedText}" FontSize="12"
                                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                          Margin="0,4,0,0"/>
                        </StackPanel>
                        <ui:Button Grid.Column="1" Content="刷新" Appearance="Secondary"
                                   Height="32" MinWidth="76" Padding="14,0"
                                   VerticalAlignment="Center"
                                   Command="{Binding RefreshCommand}"/>
                    </Grid>

                    <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                                    <ui:SymbolIcon Symbol="Building20" FontSize="18" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <ui:TextBlock Text="客户数量" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ui:TextBlock Text="{Binding CustomerCountText}" FontSize="24"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}">
                                    <ui:SymbolIcon Symbol="Box24" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <ui:TextBlock Text="产品数量" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ui:TextBlock Text="{Binding ProductCountText}" FontSize="24"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}">
                                    <ui:SymbolIcon Symbol="DocumentBulletList24" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <ui:TextBlock Text="报价数量" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ui:TextBlock Text="{Binding QuotationCountText}" FontSize="24"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource MetricCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}">
                                    <ui:SymbolIcon Symbol="People20" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <ui:TextBlock Text="负责人" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ui:TextBlock Text="{Binding OwnerCountText}" FontSize="24"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*"/>
                            <ColumnDefinition Width="1.25*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource SectionSurfaceStyle}" Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ui:TextBlock Text="金额概览" FontSize="15" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                <Grid Grid.Row="1" Margin="0,18,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ui:TextBlock Grid.Row="0" Text="总报价金额" FontSize="13"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ui:TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalAmountText}"
                                                  FontSize="16" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                    <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1"
                                            Background="{DynamicResource CardStrokeColorDefaultBrush}"
                                            Margin="0,14"/>

                                    <ui:TextBlock Grid.Row="2" Text="本月报价金额" FontSize="13"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ui:TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MonthAmountText}"
                                                  FontSize="16" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </Grid>

                                <Border Grid.Row="2" Margin="0,18,0,0"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="8" Padding="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Text="单张平均金额" FontSize="13"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <ui:TextBlock Grid.Column="1" Text="{Binding AverageAmountText}"
                                                      FontSize="15" FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource SectionSurfaceStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <ui:TextBlock Text="最近报价" FontSize="15" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                <Border Grid.Row="1" Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="8,8,0,0" Height="36" Margin="0,14,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="92"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="编号" FontSize="11" FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        <ui:TextBlock Grid.Column="1" Text="客户" FontSize="11" FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center"/>
                                        <ui:TextBlock Grid.Column="2" Text="日期" FontSize="11" FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center"/>
                                        <ui:TextBlock Grid.Column="3" Text="金额" FontSize="11" FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center" HorizontalAlignment="Right"
                                                      Margin="0,0,12,0"/>
                                    </Grid>
                                </Border>

                                <ListBox Grid.Row="2" ItemsSource="{Binding RecentQuotations}"
                                         ItemContainerStyle="{StaticResource QuoteRowContainer}"
                                         BorderThickness="0" Background="Transparent"
                                         AlternationCount="2"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="40" CornerRadius="8" Margin="0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(ItemsControl.AlternationIndex)}" Value="1">
                                                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="92"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBlock Grid.Column="0" Text="{Binding QuoteNumber}" FontSize="12"
                                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                  VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                  Margin="12,0,8,0"/>
                                                    <ui:TextBlock Grid.Column="1" Text="{Binding CustomerName}" FontSize="12"
                                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                  VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    <ui:TextBlock Grid.Column="2" Text="{Binding CreatedAt}" FontSize="12"
                                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                  VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                Margin="0,0,12,0">
                                                        <ui:TextBlock Text="{Binding Amount}" FontSize="12" FontWeight="SemiBold"
                                                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                        <ui:TextBlock Text="{Binding Currency}" FontSize="10"
                                                                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                      Margin="5,1,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
