<UserControl x:Class="Quotix.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,16"/>
        </Style>

        <Style x:Key="SectionSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="QuoteRowContainer" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20,24,24">
        <Border Style="{StaticResource AppCardModern}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ui:TextBlock Grid.Row="0" Text="首页" FontSize="22" FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                  Margin="0,0,0,16"/>

                    <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                                    <ui:SymbolIcon Symbol="Building20" FontSize="18" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <ui:TextBlock Text="客户数量" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ui:TextBlock Text="{Binding CustomerCountText}" FontSize="24"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}">
                                    <ui:SymbolIcon Symbol="Box24" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <ui:TextBlock Text="产品数量" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ui:TextBlock Text="{Binding ProductCountText}" FontSize="24"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}">
                                    <ui:SymbolIcon Symbol="DocumentBulletList24" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <ui:TextBlock Text="报价数量" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ui:TextBlock Text="{Binding QuotationCountText}" FontSize="24"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource MetricCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}">
                                    <ui:SymbolIcon Symbol="Money24" FontSize="18"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <ui:TextBlock Text="年度报价金额" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ui:TextBlock Text="{Binding AnnualRmbAmountText}"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                        <ui:TextBlock.Style>
                                            <Style TargetType="ui:TextBlock">
                                                <Setter Property="FontSize" Value="22"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAnnualUsdAmount}" Value="True">
                                                        <Setter Property="FontSize" Value="18"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:TextBlock.Style>
                                    </ui:TextBlock>
                                    <ui:TextBlock Text="{Binding AnnualUsdAmountText}"
                                                  FontSize="14"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                  Margin="0,0,0,0"
                                                  Visibility="{Binding HasAnnualUsdAmount, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.25*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource SectionSurfaceStyle}" Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <ui:TextBlock Text="{Binding ChartTitle}" FontSize="15" FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <ui:TextBlock Text="{Binding ChartTotalAmountText, StringFormat=范围合计 {0}}"
                                                      FontSize="12"
                                                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                      Margin="0,3,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                        <ui:Button Content="RMB" Height="30" MinWidth="56" Padding="12,0"
                                                   Command="{Binding SetChartCurrencyCommand}" CommandParameter="RMB">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Appearance" Value="Secondary"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRmbChartCurrency}" Value="True">
                                                            <Setter Property="Appearance" Value="Primary"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                        <ui:Button Content="USD" Height="30" MinWidth="56" Padding="12,0"
                                                   Margin="6,0,10,0"
                                                   Command="{Binding SetChartCurrencyCommand}" CommandParameter="USD">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Appearance" Value="Secondary"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUsdChartCurrency}" Value="True">
                                                            <Setter Property="Appearance" Value="Primary"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                        <ui:Button Content="周" Height="30" MinWidth="46" Padding="12,0"
                                                   Command="{Binding SetChartRangeCommand}" CommandParameter="week">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Appearance" Value="Secondary"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsWeekRange}" Value="True">
                                                            <Setter Property="Appearance" Value="Primary"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                        <ui:Button Content="月" Height="30" MinWidth="46" Padding="12,0"
                                                   Margin="6,0,0,0"
                                                   Command="{Binding SetChartRangeCommand}" CommandParameter="month">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Appearance" Value="Secondary"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMonthRange}" Value="True">
                                                            <Setter Property="Appearance" Value="Primary"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                        <ui:Button Content="年" Height="30" MinWidth="46" Padding="12,0"
                                                   Margin="6,0,0,0"
                                                   Command="{Binding SetChartRangeCommand}" CommandParameter="year">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Appearance" Value="Secondary"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsYearRange}" Value="True">
                                                            <Setter Property="Appearance" Value="Primary"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,18,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="180"/>
                                        <RowDefinition Height="24"/>
                                    </Grid.RowDefinitions>

                                    <Border Height="180" CornerRadius="8"
                                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <Viewbox Stretch="Fill">
                                            <Canvas Width="640" Height="180" ClipToBounds="True"
                                                    MouseMove="ChartCanvas_MouseMove"
                                                    MouseLeave="ChartCanvas_MouseLeave"
                                                    MouseLeftButtonDown="ChartCanvas_MouseMove">
                                                <ItemsControl ItemsSource="{Binding ChartHorizontalGridLines}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                                                  X2="{Binding X2}" Y2="{Binding Y2}"
                                                                  Stroke="{DynamicResource CardStrokeColorDefaultBrush}"
                                                                  StrokeThickness="1"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <ItemsControl ItemsSource="{Binding ChartVerticalGridLines}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                                                  X2="{Binding X2}" Y2="{Binding Y2}"
                                                                  Stroke="{DynamicResource CardStrokeColorDefaultBrush}"
                                                                  StrokeThickness="1"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <ItemsControl ItemsSource="{Binding ChartYAxisLabels}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <ui:TextBlock Text="{Binding Text}" Width="54"
                                                                          FontSize="11" TextAlignment="Right"
                                                                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Path Data="{Binding ChartAreaData}" Opacity="0.36">
                                                    <Path.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#5FB2F2" Offset="0"/>
                                                            <GradientStop Color="#145FB2F2" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Path.Fill>
                                                </Path>
                                                <Path Data="{Binding ChartLineData}"
                                                      Stroke="#5FB2F2"
                                                      StrokeThickness="3"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"/>
                                                <ItemsControl ItemsSource="{Binding ChartMarkers}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Ellipse Width="7" Height="7"
                                                                     Stroke="#5FB2F2"
                                                                     StrokeThickness="2"
                                                                     Fill="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Line X1="{Binding ChartDetailLineX}" Y1="18"
                                                      X2="{Binding ChartDetailLineX}" Y2="162"
                                                      Stroke="{DynamicResource AccentFillColorDefaultBrush}"
                                                      StrokeThickness="1"
                                                      StrokeDashArray="3,4"
                                                      Visibility="{Binding IsChartDetailVisible, Converter={StaticResource BoolToVis}}"/>
                                                <Border Width="136" Height="62" CornerRadius="6"
                                                        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        Visibility="{Binding IsChartDetailVisible, Converter={StaticResource BoolToVis}}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Canvas.Left" Value="{Binding ChartDetailX}"/>
                                                            <Setter Property="Canvas.Top" Value="{Binding ChartDetailY}"/>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Margin="12,8">
                                                        <ui:TextBlock Text="{Binding ChartDetailDate}" FontSize="12"
                                                                      FontWeight="SemiBold"
                                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                            <Ellipse Width="8" Height="8" Fill="#5FB2F2"
                                                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <ui:TextBlock Text="{Binding ChartDetailAmount}" FontSize="13"
                                                                          FontWeight="SemiBold"
                                                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>

                                    <Viewbox Grid.Row="1" Stretch="Fill">
                                        <Canvas Width="640" Height="24">
                                            <ItemsControl ItemsSource="{Binding ChartLabels}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                        <Setter Property="Canvas.Top" Value="6"/>
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <ui:TextBlock Text="{Binding Text}" FontSize="11"
                                                                      Width="40" TextAlignment="Center"
                                                                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Canvas>
                                    </Viewbox>
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Text="{Binding ChartMaxAmountText, StringFormat=峰值 {0}}"
                                                  FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    <ui:TextBlock Grid.Column="1" Text="{Binding MonthAmountText, StringFormat=本月 {0}}"
                                                  FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource SectionSurfaceStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <ui:TextBlock Text="最近报价" FontSize="15" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                <Border Grid.Row="1" Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="8,8,0,0" Height="36" Margin="0,14,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="104"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="客户" FontSize="11" FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        <ui:TextBlock Grid.Column="1" Text="时间" FontSize="11" FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center"/>
                                        <ui:TextBlock Grid.Column="2" Text="金额" FontSize="11" FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      VerticalAlignment="Center" HorizontalAlignment="Right"
                                                      Margin="0,0,12,0"/>
                                    </Grid>
                                </Border>

                                <ListBox Grid.Row="2" ItemsSource="{Binding RecentQuotations}"
                                         ItemContainerStyle="{StaticResource QuoteRowContainer}"
                                         BorderThickness="0" Background="Transparent"
                                         AlternationCount="2"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="40" CornerRadius="8" Margin="0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(ItemsControl.AlternationIndex)}" Value="1">
                                                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="104"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBlock Grid.Column="0" Text="{Binding CustomerName}" FontSize="12"
                                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                  VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                  Margin="12,0,8,0"/>
                                                    <ui:TextBlock Grid.Column="1" Text="{Binding CreatedAt}" FontSize="12"
                                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                  VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                Margin="0,0,12,0">
                                                        <ui:TextBlock Text="{Binding Amount}" FontSize="12" FontWeight="SemiBold"
                                                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                        <ui:TextBlock Text="{Binding Currency}" FontSize="10"
                                                                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                      Margin="5,1,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
