<UserControl x:Class="Quotix.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <!-- 行容器：无焦点虚线、无选中高亮 -->
        <Style x:Key="TableRowContainer" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 行模板 -->
        <DataTemplate x:Key="QuotationRowTemplate">
            <Border Height="42" CornerRadius="8" Margin="0,1"
                    Background="Transparent">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(ItemsControl.AlternationIndex)}" Value="1">
                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170*"/>
                        <ColumnDefinition Width="283*"/>
                        <ColumnDefinition Width="130*"/>
                        <ColumnDefinition Width="130*"/>
                        <ColumnDefinition Width="175*"/>
                    </Grid.ColumnDefinitions>

                    <ui:TextBlock Grid.Column="0" Text="{Binding Filename}" FontSize="13"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center"
                                  TextTrimming="CharacterEllipsis"
                                  Margin="14,0,4,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <ui:TextBlock Text="{Binding CustomerName}" FontSize="13"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      TextTrimming="CharacterEllipsis"/>
                        <ui:TextBlock Text="{Binding CustomerContact}" FontSize="11"
                                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                      TextTrimming="CharacterEllipsis"
                                      Margin="0,1,0,0"/>
                    </StackPanel>
                    <Grid Grid.Column="2" Margin="-15,0,0,0">
                        <ui:TextBlock Text="{Binding CreatedAt}" FontSize="13"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      TextTrimming="CharacterEllipsis"/>
                    </Grid>
                    <Grid Grid.Column="3" VerticalAlignment="Center"
                          HorizontalAlignment="Stretch"
                          Margin="0,0,18,0">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <ui:TextBlock FontSize="14" FontWeight="Bold"
                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                          VerticalAlignment="Center">
                                <Run Text="{Binding TotalAmount, StringFormat={}{0:N2}}"/>
                            </ui:TextBlock>
                            <ui:TextBlock Text="{Binding Currency}" FontSize="10"
                                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                          VerticalAlignment="Center"
                                          Margin="5,1,0,0"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Column="4" Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="-15,0,0,0">
                        <ui:Button Appearance="Primary" Height="30" FontSize="12"
                                   MinWidth="52" Padding="8,0"
                                   CommandParameter="{Binding Id}"
                                   Click="EditButton_Click">
                            编辑
                        </ui:Button>
                        <ui:Button Appearance="Secondary" Height="30" FontSize="12"
                                   MinWidth="52" Padding="8,0" Margin="6,0"
                                   CommandParameter="{Binding Id}"
                                   Click="ExportButton_Click">
                            导出
                        </ui:Button>
                        <ui:Button Appearance="Danger" Height="30" FontSize="12"
                                   MinWidth="52" Padding="8,0"
                                   CommandParameter="{Binding Id}"
                                   Click="DeleteButton_Click">
                            删除
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24,20,24,24">
        <Border Style="{StaticResource AppCardModern}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ═══ Row 0：记录数 + 搜索框 ═══ -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ui:TextBlock Grid.Column="0"
                                  FontSize="16" FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center">
                        <Run Text="{Binding Quotations.Count, Mode=OneWay, StringFormat={}{0}}"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                        <Run Text="条记录"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                    </ui:TextBlock>

                    <Border Grid.Column="1" CornerRadius="8" MinWidth="220" Height="34"
                            HorizontalAlignment="Right"
                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Search20" FontSize="14"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <TextBox Grid.Column="1" x:Name="SearchBox" Text=""
                                     FontSize="13" VerticalContentAlignment="Center"
                                     BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                     TextChanged="SearchBox_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  VerticalAlignment="Center"
                                                                  Margin="10,0,8,0"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══ Row 1：自定义表头 ═══ -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8,8,0,0"
                        Padding="0,10"
                        Height="38"
                        Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170*"/>
                            <ColumnDefinition Width="283*"/>
                            <ColumnDefinition Width="130*"/>
                            <ColumnDefinition Width="130*"/>
                            <ColumnDefinition Width="175*"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock Grid.Column="0" Text="文件名" FontSize="11" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      VerticalAlignment="Center"
                                      Margin="14,0,0,0"/>
                        <ui:TextBlock Grid.Column="1" Text="客户" FontSize="11" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      VerticalAlignment="Center"/>
                        <ui:TextBlock Grid.Column="2" Text="创建时间" FontSize="11" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                        <ui:TextBlock Grid.Column="3" Text="总金额" FontSize="11" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Margin="0,0,18,0"/>
                        <ui:TextBlock Grid.Column="4" Text="操作" FontSize="11" FontWeight="SemiBold"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ═══ Row 2：列表 ═══ -->
                <ListBox Grid.Row="2"
                         x:Name="QuotationList"
                         ItemsSource="{Binding Quotations}"
                         ItemContainerStyle="{StaticResource TableRowContainer}"
                         ItemTemplate="{StaticResource QuotationRowTemplate}"
                         AlternationCount="2"
                         BorderThickness="0"
                         Background="Transparent"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.ScrollUnit="Pixel"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
