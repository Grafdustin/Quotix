<UserControl x:Class="Quotix.Views.NewQuotationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,36">

                <!-- ═══════════════ 页面标题区 ═══════════════ -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：页面标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="10"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="DocumentAdd24" FontSize="20"
                                           Foreground="{DynamicResource AccentFillColorPrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <ui:TextBlock Text="新建报价单" FontSize="20" FontWeight="Bold"
                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:TextBlock Text="创建并保存一份新的报价单" FontSize="12"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 右侧：日期选择 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:TextBlock Text="日期" FontSize="12" FontWeight="Medium"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker x:Name="QuoteDatePicker"
                                    SelectedDate="{Binding QuoteDateValue}"
                                    Width="160" Height="34" FontSize="13"
                                    VerticalContentAlignment="Center"
                                    Loaded="QuoteDatePicker_Loaded">
                                <DatePicker.Template>
                                    <ControlTemplate TargetType="DatePicker">
                                        <ControlTemplate.Resources>
                                            <Style TargetType="DatePickerTextBox">
                                                <Setter Property="IsReadOnly" Value="True"/>
                                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                <Setter Property="VerticalAlignment" Value="Stretch"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="DatePickerTextBox">
                                                            <Border Background="Transparent"
                                                                    HorizontalAlignment="Stretch"
                                                                    VerticalAlignment="Stretch">
                                                                <ScrollViewer x:Name="PART_ContentHost"
                                                                              HorizontalAlignment="Stretch"
                                                                              VerticalAlignment="Center"
                                                                              Margin="0"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ControlTemplate.Resources>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 日期文本输入区 -->
                                            <Border x:Name="PART_Border"
                                                    Grid.Column="0"
                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                    BorderThickness="1,1,1,1"
                                                    CornerRadius="6,0,0,6"
                                                    Height="{TemplateBinding Height}">
                                                <DatePickerTextBox x:Name="PART_TextBox"
                                                                   HorizontalContentAlignment="Center"
                                                                   VerticalContentAlignment="Center"
                                                                   FontSize="{TemplateBinding FontSize}"
                                                                   Padding="0"
                                                                   Background="Transparent"
                                                                   BorderThickness="0"
                                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            </Border>

                                            <!-- 日历触发按钮 -->
                                            <Button x:Name="PART_Button"
                                                    Grid.Column="1"
                                                    Width="34" Height="{TemplateBinding Height}"
                                                    Padding="0" Margin="0"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    VerticalAlignment="Stretch">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd"
                                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                BorderThickness="0,1,1,1"
                                                                CornerRadius="0,6,6,0"
                                                                Padding="6"
                                                                VerticalAlignment="Stretch">
                                                            <Grid>
                                                                <Path x:Name="CalendarGlyph"
                                                                      Data="M7,2H9V4H15V2H17V4H19A2,2 0 0,1 21,6V20A2,2 0 0,1 19,22H5A2,2 0 0,1 3,20V6A2,2 0 0,1 5,4H7V2M19,10H5V20H19V10M9,14V16H7V14H9M13,14V16H11V14H13M17,14V16H15V14H17"
                                                                      Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                                                      Stretch="Uniform"
                                                                      Width="18" Height="18"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="CalendarGlyph" Property="Fill"
                                                                        Value="{DynamicResource AccentFillColorPrimaryBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- 日历弹出层 — 右上角对齐 -->
                                            <Popup x:Name="PART_Popup"
                                                   Grid.Column="1"
                                                   PlacementTarget="{Binding ElementName=PART_Button}"
                                                   Placement="Top"
                                                   StaysOpen="False"
                                                   AllowsTransparency="True">
                                                <Border Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                                                        BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="6">
                                                    <StackPanel>
                                                        <!-- 日历本体 -->
                                                        <Calendar x:Name="PART_Calendar"
                                                                  SelectedDate="{TemplateBinding SelectedDate}"
                                                                  DisplayDate="{TemplateBinding DisplayDate}"
                                                                  FirstDayOfWeek="{TemplateBinding FirstDayOfWeek}"
                                                                  IsTodayHighlighted="True"
                                                                  FontSize="12"
                                                                  Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                                                            <Calendar.CalendarDayButtonStyle>
                                                                <Style TargetType="CalendarDayButton">
                                                                    <Setter Property="FontSize" Value="12"/>
                                                                    <Setter Property="Background"
                                                                            Value="{DynamicResource SolidBackgroundFillColorBaseBrush}"/>
                                                                    <Setter Property="BorderThickness" Value="0"/>
                                                                    <Setter Property="Foreground"
                                                                            Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                </Style>
                                                            </Calendar.CalendarDayButtonStyle>
                                                            <Calendar.CalendarButtonStyle>
                                                                <Style TargetType="CalendarButton">
                                                                    <Setter Property="FontSize" Value="11"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    <Setter Property="Foreground"
                                                                            Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                    <Setter Property="Background"
                                                                            Value="{DynamicResource SolidBackgroundFillColorBaseBrush}"/>
                                                                    <Setter Property="BorderThickness" Value="0"/>
                                                                    <Setter Property="Height" Value="28"/>
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                </Style>
                                                            </Calendar.CalendarButtonStyle>
                                                            <Calendar.CalendarItemStyle>
                                                                <Style TargetType="CalendarItem">
                                                                    <Setter Property="Background"
                                                                            Value="{DynamicResource SolidBackgroundFillColorBaseBrush}"/>
                                                                    <Setter Property="BorderThickness" Value="0"/>
                                                                </Style>
                                                            </Calendar.CalendarItemStyle>
                                                        </Calendar>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </ControlTemplate>
                                </DatePicker.Template>
                            </DatePicker>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ═══════════════ 工具栏：数据源 + 币种 + 文件名 ═══════════════ -->
                <Border Style="{StaticResource AppCardModern}"
                        Padding="20,16" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- 数据源（快速输入） -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <ui:TextBlock Text="数据源" FontSize="12" FontWeight="Medium"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ui:Button x:Name="QuickNDTButton" Content="NDT"
                                       MinWidth="56" Height="34" FontSize="13"
                                       Appearance="{Binding QuickInputDatabase, Converter={StaticResource QuickDbAppearance}, ConverterParameter=NDT}"
                                       Click="QuickNDTButton_Click"/>
                            <ui:Button x:Name="QuickRVIButton" Content="RVI"
                                       MinWidth="56" Height="34" FontSize="13" Margin="6,0,0,0"
                                       Appearance="{Binding QuickInputDatabase, Converter={StaticResource QuickDbAppearance}, ConverterParameter=RVI}"
                                       Click="QuickRVIButton_Click"/>
                        </StackPanel>

                        <Border Width="1" Margin="0,6" VerticalAlignment="Stretch"
                                Background="{DynamicResource CardStrokeColorDefaultBrush}"/>

                        <!-- 币种 -->
                        <StackPanel Orientation="Horizontal" Margin="20,0,16,0">
                            <ui:TextBlock Text="币种" FontSize="12" FontWeight="Medium"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ui:Button Content="¥ RMB" Height="34" MinWidth="72" FontSize="13"
                                       Command="{Binding SwitchCurrencyCommand}" CommandParameter="RMB"
                                       Appearance="{Binding Currency, Converter={StaticResource CurrencyBg}, ConverterParameter=RMB}"/>
                            <ui:Button Content="$ USD" Height="34" MinWidth="72" FontSize="13" Margin="6,0,0,0"
                                       Command="{Binding SwitchCurrencyCommand}" CommandParameter="USD"
                                       Appearance="{Binding Currency, Converter={StaticResource CurrencyBg}, ConverterParameter=USD}"/>
                        </StackPanel>

                        <Border Width="1" Margin="0,6" VerticalAlignment="Stretch"
                                Background="{DynamicResource CardStrokeColorDefaultBrush}"/>

                        <!-- 文件名 -->
                        <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                            <ui:TextBlock Text="文件名" FontSize="12" FontWeight="Medium"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ui:TextBox Text="{Binding Filename, UpdateSourceTrigger=PropertyChanged}"
                                        Width="180" Height="34" VerticalContentAlignment="Center"
                                        FontSize="13" PlaceholderText="报价单名称"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ 公司 + 客户 双栏 ═══════════════ -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 公司信息 -->
                    <Border Grid.Column="0" Style="{StaticResource AppCardModern}" Padding="24,22">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <Border Style="{StaticResource CardTitleIcon}">
                                    <ui:SymbolIcon Symbol="Person24" FontSize="16"
                                                   Foreground="{DynamicResource AccentFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ui:TextBlock Text="公司信息" FontSize="15" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 负责人 -->
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <ui:TextBlock Text="负责人" FontSize="12" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  Margin="0,0,0,6"/>
                                    <ui:TextBox x:Name="CompanyContactBox"
                                                Text="{Binding CompanyContact, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="输入姓名"
                                                GotFocus="OwnerBox_GotFocus" LostFocus="QuickBox_LostFocus"
                                                TextChanged="QuickBox_TextChanged"/>
                                </StackPanel>

                                <!-- 电话 -->
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <ui:TextBlock Text="电话" FontSize="12" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  Margin="0,0,0,6"/>
                                    <ui:TextBox Text="{Binding CompanyTel, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- 手机 -->
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <ui:TextBlock Text="手机" FontSize="12" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  Margin="0,0,0,6"/>
                                    <ui:TextBox Text="{Binding CompanyPhone, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- 邮箱 -->
                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <ui:TextBlock Text="邮箱" FontSize="12" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  Margin="0,0,0,6"/>
                                    <ui:TextBox Text="{Binding CompanyEmail, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 客户信息 -->
                    <Border Grid.Column="2" Style="{StaticResource AppCardModern}" Padding="24,22">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <Border Style="{StaticResource CardTitleIcon}">
                                    <ui:SymbolIcon Symbol="People24" FontSize="16"
                                                   Foreground="{DynamicResource AccentFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ui:TextBlock Text="客户信息" FontSize="15" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 公司名称 -->
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <ui:TextBlock Text="公司名称" FontSize="12" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  Margin="0,0,0,6"/>
                                    <ui:TextBox x:Name="CustomerNameBox"
                                                Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="输入公司名"
                                                GotFocus="CustomerBox_GotFocus" LostFocus="QuickBox_LostFocus"
                                                TextChanged="QuickBox_TextChanged"/>
                                </StackPanel>

                                <!-- 联系人 -->
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <ui:TextBlock Text="联系人" FontSize="12" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  Margin="0,0,0,6"/>
                                    <ui:TextBox Text="{Binding CustomerContact, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- 联系方式 -->
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <ui:TextBlock Text="联系方式" FontSize="12" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  Margin="0,0,0,6"/>
                                    <ui:TextBox Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- 邮箱 -->
                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <ui:TextBlock Text="邮箱" FontSize="12" FontWeight="Medium"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  Margin="0,0,0,6"/>
                                    <ui:TextBox Text="{Binding CustomerEmail, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ═══════════════ 报价说明 ═══════════════ -->
                <Border Style="{StaticResource AppCardModern}" Padding="24,22" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Border Style="{StaticResource CardTitleIcon}">
                                <ui:SymbolIcon Symbol="DocumentBulletList24" FontSize="16"
                                               Foreground="{DynamicResource AccentFillColorPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ui:TextBlock Text="报价说明" FontSize="15" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                          VerticalAlignment="Center"
                                          Margin="10,0,0,0"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <ui:TextBlock Text="有效期" FontSize="12" FontWeight="Medium"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              Margin="0,0,0,6"/>
                                <ui:TextBox Text="{Binding Validity, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <ui:TextBlock Text="付款方式" FontSize="12" FontWeight="Medium"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              Margin="0,0,0,6"/>
                                <ui:TextBox Text="{Binding Payment, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <ui:TextBlock Text="交货期" FontSize="12" FontWeight="Medium"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              Margin="0,0,0,6"/>
                                <ui:TextBox Text="{Binding DeliveryTime, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <ui:TextBlock Text="交货方式" FontSize="12" FontWeight="Medium"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              Margin="0,0,0,6"/>
                                <ui:TextBox Text="{Binding DeliveryMethod, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ 报价表单 ═══════════════ -->
                <Border Style="{StaticResource AppCardModern}" Padding="0">
                    <StackPanel>
                        <!-- 表单标题 -->
                        <StackPanel Orientation="Horizontal" Margin="24,22,24,0">
                            <ui:SymbolIcon Symbol="Calculator24" FontSize="16"
                                           Foreground="{DynamicResource AccentFillColorPrimaryBrush}"/>
                            <ui:TextBlock Text="报价表单" FontSize="15" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                          Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- 表头 -->
                        <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                Padding="14,10" Margin="24,16,24,0" CornerRadius="8,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" Text="#" FontSize="11" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ui:TextBlock Grid.Column="1" Text="产品名称" FontSize="11" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ui:TextBlock Grid.Column="2" Text="编号" FontSize="11" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ui:TextBlock Grid.Column="3" Text="说明" FontSize="11" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ui:TextBlock Grid.Column="4" Text="数量" FontSize="11" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ui:TextBlock Grid.Column="5" Text="单价" FontSize="11" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ui:TextBlock Grid.Column="6" Text="总价" FontSize="11" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- 数据行 -->
                        <ItemsControl x:Name="ItemsControlList" ItemsSource="{Binding Items}"
                                      Margin="24,0,24,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="10,6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource SubtleFillColorTransparentBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- # -->
                                            <ui:TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          FontSize="12" FontWeight="Medium"
                                                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                          Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Converter={StaticResource Index}}"/>

                                            <!-- 产品名称 -->
                                            <ui:TextBox Grid.Column="1"
                                                        Text="{Binding ItemName, UpdateSourceTrigger=PropertyChanged}"
                                                        FontSize="13" Height="34" VerticalContentAlignment="Center"
                                                        Margin="0,0,8,0"/>

                                            <!-- 编号 -->
                                            <ui:TextBox Grid.Column="2"
                                                        Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                                                        FontSize="13" Height="34" VerticalContentAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        GotFocus="CodeBox_GotFocus" LostFocus="QuickBox_LostFocus"
                                                        TextChanged="CodeBox_TextChanged"/>

                                            <!-- 说明 -->
                                            <ui:TextBox Grid.Column="3"
                                                        Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                        FontSize="13" Height="34" VerticalContentAlignment="Center"
                                                        Margin="0,0,8,0"/>

                                            <!-- 数量 -->
                                            <ui:TextBox Grid.Column="4"
                                                        Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                        FontSize="13" Height="34" VerticalContentAlignment="Center"
                                                        TextAlignment="Center" Margin="0,0,8,0"/>

                                            <!-- 单价 -->
                                            <ui:TextBox Grid.Column="5"
                                                        Text="{Binding UnitPrice, Converter={StaticResource ZeroToEmpty}, UpdateSourceTrigger=LostFocus}"
                                                        FontSize="13" Height="34" VerticalContentAlignment="Center"
                                                        TextAlignment="Center" Margin="0,0,8,0"/>

                                            <!-- 总价 -->
                                            <ui:TextBlock Grid.Column="6"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          FontSize="14" FontWeight="SemiBold"
                                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                                <ui:TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource Multiply}">
                                                        <Binding Path="Quantity"/>
                                                        <Binding Path="UnitPrice"/>
                                                    </MultiBinding>
                                                </ui:TextBlock.Text>
                                            </ui:TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 底部操作栏 -->
                        <Border Margin="24,16,24,22" Padding="20,16"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 左侧操作 -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:Button Content="添加" Icon="{ui:SymbolIcon Add20}"
                                               Appearance="Primary" Height="34" FontSize="13"
                                               Command="{Binding AddItemCommand}"/>
                                    <ui:Button Content="移除" Icon="{ui:SymbolIcon Subtract20}"
                                               Appearance="Danger" Height="34" FontSize="13" Margin="6,0"
                                               Command="{Binding RemoveItemCommand}"/>

                                    <Border Width="1" Margin="14,6"
                                            Background="{DynamicResource CardStrokeColorDefaultBrush}"/>

                                    <ui:Button Content="计算器" Appearance="Secondary"
                                               Height="34" FontSize="13"
                                               Command="{Binding PriceCalculatorCommand}"/>
                                    <ui:Button Content="重置" Appearance="Secondary"
                                               Height="34" FontSize="13" Margin="6,0"
                                               Command="{Binding ResetFormCommand}"/>

                                    <Border Width="1" Margin="14,6"
                                            Background="{DynamicResource CardStrokeColorDefaultBrush}"/>

                                    <ui:Button Content="{Binding SaveButtonText}" Appearance="Primary"
                                               Height="34" FontSize="13"
                                               Command="{Binding SaveCommand}"/>
                                </StackPanel>

                                <!-- 总计 -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="20,0,0,0">
                                    <ui:TextBlock Text="总计" FontSize="14"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ui:TextBlock Text="{Binding CurrencySymbol}" FontSize="14" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                  VerticalAlignment="Center"/>
                                    <ui:TextBlock Text="{Binding GrandTotal, StringFormat={}{0:N2}}"
                                                  FontSize="18" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                  VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════ 快速搜索 Popup ═══════════════ -->
        <Popup x:Name="QuickSearchPopup" Placement="Bottom" StaysOpen="False"
               AllowsTransparency="True" PopupAnimation="Fade"
               IsOpen="{Binding IsQuickSearchVisible}">
            <Border Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    MinWidth="380" MaxWidth="520" MaxHeight="360">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="6" Opacity="0.18" BlurRadius="20" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="12,12,0,0" Padding="16,11">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Search24" FontSize="14"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBlock FontSize="12"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Margin="8,0,0,0">
                                <Run Text="搜索 "/>
                                <Run Text="{Binding QuickInputDatabase}" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding QuickSearchResults.Count, StringFormat=共 {0} 条, Mode=OneWay}"/>
                            </ui:TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 结果列表 -->
                    <ListBox Grid.Row="1" x:Name="QuickResultsList"
                             ItemsSource="{Binding QuickSearchResults}"
                             BorderThickness="0" Background="Transparent"
                             PreviewMouseLeftButtonUp="QuickResultsList_PreviewMouseLeftButtonUp"
                             PreviewKeyDown="QuickResultsList_PreviewKeyDown">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Name="ItemBorder" Padding="16,10"
                                                    Background="Transparent"
                                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background"
                                                            Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <ui:TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                  TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <ui:TextBlock Text="{Binding Subtitle}" FontSize="11"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      Margin="0,0,12,0"/>
                                        <ui:TextBlock FontSize="12" FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                      Visibility="{Binding PriceText, Converter={StaticResource StringToVis}}">
                                            <Run Text="¥"/><Run Text="{Binding PriceText}"/>
                                        </ui:TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Popup>

    </Grid>
</UserControl>
