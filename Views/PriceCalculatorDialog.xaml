<ui:FluentWindow x:Class="Quotix.Views.PriceCalculatorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="单价计算器" Height="520" Width="840"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowCornerPreference="Round">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 操作栏 -->
        <Border Grid.Row="0" Style="{StaticResource AppCardModern}"
                Padding="16,14" Margin="0,0,0,16"
                MouseLeftButtonDown="DragArea_MouseLeftButtonDown">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 运算方式 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Style="{StaticResource LabelBadge}" Width="56">
                            <ui:TextBlock Text="运算" FontSize="12"/>
                        </Border>
                        <ComboBox x:Name="OperationCombo" Width="100" SelectedIndex="1"
                                  Height="34" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="倍数 (×)"/>
                            <ComboBoxItem Content="除法 (÷)"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- 数值 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                        <Border Style="{StaticResource LabelBadge}" Width="56">
                            <ui:TextBlock Text="数值" FontSize="12"/>
                        </Border>
                        <ui:TextBox x:Name="ValueInput" ClearButtonEnabled="False" Width="100" FontSize="14"
                                    VerticalContentAlignment="Center" Height="34"
                                    Text="0" PreviewTextInput="NumberPreviewTextInput"/>
                    </StackPanel>

                    <!-- 取整 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0,0,0">
                        <Border Style="{StaticResource LabelBadge}" Width="56">
                            <ui:TextBlock Text="取整" FontSize="12"/>
                        </Border>
                        <ComboBox x:Name="RoundModeCombo" Width="120" SelectedIndex="1"
                                  Height="34" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="不取整"/>
                            <ComboBoxItem Content="向上取整"/>
                            <ComboBoxItem Content="向下取整"/>
                            <ComboBoxItem Content="四舍五入"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- 操作按钮 -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <ui:Button Content="计算" Appearance="Primary" Height="34"
                                   MinWidth="80" Click="CalculateClick"/>
                        <ui:Button Content="撤销" Appearance="Danger" Height="34"
                                   MinWidth="80" Margin="6,0,0,0" Click="UndoClick"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 计算结果列表 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                                CornerRadius="10" Padding="16,12"
                                Margin="0,0,0,8"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 产品名 -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <ui:TextBlock Text="{Binding ItemName}" FontSize="14" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                  TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- 原价 -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="16,0">
                                    <ui:TextBlock Text="原价" FontSize="11"
                                                  Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="6" Padding="10,6" MinWidth="120">
                                        <ui:TextBlock Text="{Binding OriginalPrice}"
                                                      FontSize="13" Height="28"
                                                      VerticalAlignment="Center"
                                                      TextAlignment="Right"/>
                                    </Border>
                                </StackPanel>

                                <!-- 箭头 -->
                                <ui:SymbolIcon Grid.Column="2" Symbol="ArrowRight20" FontSize="18"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="8,0"/>

                                <!-- 新单价 -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="16,0,0,0">
                                    <ui:TextBlock Text="新单价" FontSize="11"
                                                  Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="6" Padding="10,6" MinWidth="120">
                                        <ui:TextBlock Text="{Binding UnitPrice, StringFormat={}{0:F2}}"
                                                      FontSize="13" Height="28"
                                                      FontWeight="SemiBold"
                                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                      VerticalAlignment="Center"
                                                      TextAlignment="Right"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="2" Margin="0,16,0,0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="0,16,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <ui:TextBlock Text="原总价" FontSize="12"
                                  Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                  VerticalAlignment="Center"/>
                    <ui:TextBlock x:Name="OriginalTotalText" Text="0.00" FontSize="15"
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                  Margin="8,0,24,0" VerticalAlignment="Center"/>
                    <ui:TextBlock Text="新总价" FontSize="12"
                                  Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                  VerticalAlignment="Center"/>
                    <ui:TextBlock x:Name="NewTotalText" Text="0.00" FontSize="15"
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                  Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="取消" Appearance="Secondary" Height="36" Width="100"
                               Click="CancelClick"/>
                    <ui:Button Content="应用" Appearance="Primary" Height="36" Width="100"
                               Margin="8,0,0,0" Click="ApplyClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
