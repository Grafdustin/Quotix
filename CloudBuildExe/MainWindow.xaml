<ui:FluentWindow x:Class="QuotixCloudBuild.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Quotix 云端发布"
        Width="900" Height="640"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">

    <Grid Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- ═══════ 左侧控制面板 ═══════ -->
        <Border Grid.Column="0" Grid.Row="0"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                Padding="14">

            <StackPanel>

                <TextBlock Text="QUOTIX BUILD CONSOLE"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="0,0,0,14"/>

                <!-- 状态块 -->
                <Border CornerRadius="6"
                        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                        Padding="10"
                        Margin="0,0,0,10">

                    <StackPanel>
                        <TextBlock Text="STATUS"
                                   FontSize="10"
                                   Opacity="0.7"/>

                        <TextBlock x:Name="BuildStatusText"
                                   Text="IDLE"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 版本 -->
                <TextBlock Text="VERSION" FontSize="10" Opacity="0.7"/>
                <ui:TextBox x:Name="CurrentVersionBox"
                            IsReadOnly="True"
                            Height="30"
                            Margin="0,4,0,10"/>

                <TextBlock Text="NEXT VERSION" FontSize="10" Opacity="0.7"/>
                <ui:TextBox x:Name="NewVersionBox"
                            Height="30"
                            Margin="0,4,0,10"
                            PlaceholderText="1.0.57"/>

                <!-- 更新日志 -->
                <TextBlock Text="CHANGELOG" FontSize="10" Opacity="0.7" Margin="0,0,0,4"/>
                <ui:TextBox x:Name="ChangelogBox"
                            Height="100"
                            Margin="0,4,0,10"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            PlaceholderText="# 新增功能&#x0a;- 优化性能"/>

                <!-- 发布按钮 -->
                <ui:Button x:Name="StartButton"
                           Content="▶ RUN BUILD"
                           Appearance="Primary"
                           Height="36"
                           FontSize="12"
                           Click="StartButton_Click"
                           Margin="0,0,0,8"/>

                <ui:Button x:Name="CancelButton"
                           Content="■ STOP"
                           Appearance="Secondary"
                           Height="30"
                           IsEnabled="False"
                           Click="CancelButton_Click"/>

                <!-- 进度 -->
                <TextBlock Text="PROGRESS" FontSize="10" Opacity="0.7"
                           Margin="0,14,0,4"/>

                <ProgressBar x:Name="ProgressBar"
                             Height="6"
                             Maximum="100"/>

                <TextBlock x:Name="ProgressText"
                           FontSize="11"
                           Margin="0,6,0,0"/>

            </StackPanel>
        </Border>

        <!-- ═══════ 右侧终端区域 ═══════ -->
        <Border Grid.Column="1" Grid.Row="0"
                Background="#0B0F14"
                Padding="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 顶部状态行 -->
                <StackPanel Orientation="Horizontal"
                            Grid.Row="0"
                            Margin="0,0,0,8">

                    <TextBlock Text="> build session started"
                               Foreground="#4CAF50"
                               FontSize="12"/>

                    <TextBlock x:Name="ElapsedText"
                               Foreground="#888"
                               FontSize="11"
                               Margin="12,0,0,0"/>
                </StackPanel>

                <!-- 控制台输出 -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              x:Name="LogScroller">
                    <ui:TextBox x:Name="LogBox"
                                IsReadOnly="True"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                FontFamily="Cascadia Code,Consolas"
                                FontSize="12"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#D6DEEB"
                                Padding="4"/>
                </ScrollViewer>

            </Grid>
        </Border>

        <!-- ═══════ 底部状态栏 ═══════ -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="#11151C"
                Height="34">

            <Grid Margin="12,0">
                <TextBlock x:Name="StatusHintText"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="#888"/>
            </Grid>
        </Border>

    </Grid>

</ui:FluentWindow>
