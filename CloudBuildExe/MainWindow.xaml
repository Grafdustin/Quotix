<ui:FluentWindow x:Class="QuotixCloudBuild.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Quotix 云端发布"
        Width="580" Height="680"
        MinWidth="480" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <ui:TitleBar Grid.Row="0" Height="32"
                     Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                     ShowMinimize="True" ShowMaximize="True" ShowClose="True">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                    <ui:SymbolIcon Symbol="CloudArrowUp24" FontSize="16"
                                   Foreground="{DynamicResource AccentFillColorPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    <TextBlock Text="Quotix 云端发布" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- 主内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="24,16,24,12"
                      Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
            <StackPanel>

                <!-- ═══════ 版本号 ═══════ -->
                <Border Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                        CornerRadius="8" Padding="18,16" Margin="0,0,0,12"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border CornerRadius="6" Width="28" Height="28"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                    VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="NumberSymbol24" FontSize="14"
                                               Foreground="{DynamicResource AccentFillColorPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="版本信息" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="当前版本" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <ui:TextBox Grid.Column="2" x:Name="CurrentVersionBox"
                                        IsReadOnly="True" Height="32"
                                        VerticalContentAlignment="Center" FontSize="13"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="新版本" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <ui:TextBox Grid.Column="2" x:Name="NewVersionBox"
                                        Height="32" VerticalContentAlignment="Center" FontSize="13"
                                        PlaceholderText="例如 1.0.57"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════ 更新日志 ═══════ -->
                <Border Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                        CornerRadius="8" Padding="18,16" Margin="0,0,0,12"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border CornerRadius="6" Width="28" Height="28"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                    VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="TextBulletListSquare24" FontSize="14"
                                               Foreground="{DynamicResource AccentFillColorPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="更新日志" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="以 # 开头的行作为章节标题，其余为内容" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Margin="0,0,0,8"/>
                        <ui:TextBox x:Name="ChangelogBox"
                                    Height="140" FontSize="13"
                                    AcceptsReturn="True" TextWrapping="Wrap"
                                    VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Border>

                <!-- ═══════ 构建进度 ═══════ -->
                <Border x:Name="ProgressBorder"
                        Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                        CornerRadius="8" Padding="18,16" Margin="0,0,0,12"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border CornerRadius="6" Width="28" Height="28"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                    VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="DataBarVertical24" FontSize="14"
                                               Foreground="{DynamicResource AccentFillColorPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="构建进度" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock x:Name="ElapsedText" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>

                        <ProgressBar x:Name="ProgressBar" Height="6" Minimum="0" Maximum="100"
                                     Value="0" Margin="0,0,0,8"
                                     Foreground="{DynamicResource AccentFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="ProgressText" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="BuildStatusText" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentFillColorPrimaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ═══════ 详细日志 ═══════ -->
                <Expander Margin="0,0,0,4">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Terminal24" FontSize="14"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="详细日志" FontSize="12" Margin="8,0,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Expander.Header>
                    <ui:TextBox x:Name="LogBox"
                                Height="110" IsReadOnly="True"
                                AcceptsReturn="True" TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                FontFamily="Cascadia Code,Consolas"
                                FontSize="11"
                                Padding="12"/>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧状态提示 -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusHintText" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- 右侧按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button x:Name="CancelButton"
                               Content="取消"
                               Appearance="Secondary"
                               Height="32" MinWidth="80" FontSize="13"
                               IsEnabled="False"
                               Click="CancelButton_Click"
                               Margin="0,0,8,0"/>
                    <ui:Button x:Name="StartButton"
                               Content="开始发布"
                               Icon="{ui:SymbolIcon CloudArrowUp20}"
                               Appearance="Primary"
                               Height="32" MinWidth="110" FontSize="13"
                               Click="StartButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</ui:FluentWindow>
