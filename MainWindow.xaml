<ui:FluentWindow x:Class="Quotix.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Quotix"
        xmlns:vm="clr-namespace:Quotix.ViewModels"
        xmlns:views="clr-namespace:Quotix.Views"
        xmlns:common="clr-namespace:Quotix.Common"
        Title="Quotix"
        Height="860" Width="1300"
        MinHeight="640" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="None"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate DataType="{x:Type vm:NewQuotationViewModel}">
            <views:NewQuotationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductDatabaseViewModel}">
            <views:ProductDatabaseView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HeaderDatabaseViewModel}">
            <views:HeaderDatabaseView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <ui:TitleBar Grid.Row="0"
                     x:Name="TitleBar" Height="30"
                     Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                     ShowMinimize="True"
                     ShowMaximize="True"
                     ShowClose="True">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                    <Image x:Name="TitleBarIconImage" Width="14" Height="14"
                           Stretch="Uniform" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Quotix" FontSize="12"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- 主布局：左侧导航 + 右侧内容 + 设置覆盖层 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航栏 -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 导航菜单 -->
                    <ui:NavigationView
                        Grid.Row="0"
                        x:Name="RootNavView"
                        PaneDisplayMode="Left"
                        IsPaneOpen="True"
                        OpenPaneLength="240"
                        CompactPaneLength="48"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleVisible="False"
                        Margin="0"
                        Background="Transparent">

                        <ui:NavigationView.PaneHeader>
                            <StackPanel x:Name="HeaderButtonsPanel" Orientation="Horizontal"
                                        HorizontalAlignment="Left" Margin="0,4,0,0">
                                <!-- 每个按钮放在 48px(=CompactPaneLength) 的图标列槽中并水平居中，
                                     使其图标与下方导航项图标在同一列中心(x=24)对齐；按钮本体宽度保持 36 不变 -->
                                <Grid Width="48">
                                    <Button x:Name="PaneToggleButton" Height="36" Width="36"
                                            HorizontalAlignment="Center"
                                            Background="Transparent"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            BorderThickness="0" Cursor="Hand"
                                            Padding="0"
                                            Click="TogglePane_Click">
                                        <Grid Width="18" Height="18">
                                            <ui:SymbolIcon x:Name="PaneToggleIcon"
                                                           FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </Grid>
                                <Grid Width="48">
                                    <Button x:Name="ThemeToggleButton" Height="36" Width="36"
                                            HorizontalAlignment="Center"
                                            Background="Transparent"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            BorderThickness="0" Cursor="Hand"
                                            Padding="0"
                                            Click="ToggleTheme_Click">
                                        <Grid Width="18" Height="18">
                                            <ui:SymbolIcon x:Name="ThemeIcon" Symbol="WeatherMoon20" FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </ui:NavigationView.PaneHeader>

                        <ui:NavigationView.Resources>
                            <!-- 导航项默认前景色：适配深色/浅色模式 -->
                            <Style TargetType="ui:NavigationViewItem" BasedOn="{StaticResource {x:Type ui:NavigationViewItem}}">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </Style>
                        </ui:NavigationView.Resources>

                        <ui:NavigationView.MenuItems>
                            <ui:NavigationViewItem Content="首页"
                                Tag="dashboard"
                                Click="OnNavItemClick">
                                <ui:NavigationViewItem.Icon>
                                    <ui:SymbolIcon Symbol="Home24"/>
                                </ui:NavigationViewItem.Icon>
                            </ui:NavigationViewItem>
                            <ui:NavigationViewItem Content="新建报价"
                                Tag="new-quotation"
                                Click="OnNavItemClick">
                                <ui:NavigationViewItem.Icon>
                                    <ui:SymbolIcon Symbol="DocumentAdd24"/>
                                </ui:NavigationViewItem.Icon>
                            </ui:NavigationViewItem>
                            <ui:NavigationViewItem Content="报价历史"
                                Tag="history"
                                Click="OnNavItemClick">
                                <ui:NavigationViewItem.Icon>
                                    <ui:SymbolIcon Symbol="History24"/>
                                </ui:NavigationViewItem.Icon>
                            </ui:NavigationViewItem>
                            <ui:NavigationViewItem Content="产品列表"
                                Tag="product-db"
                                Click="OnNavItemClick">
                                <ui:NavigationViewItem.Icon>
                                    <ui:SymbolIcon Symbol="Box24"/>
                                </ui:NavigationViewItem.Icon>
                            </ui:NavigationViewItem>
                            <ui:NavigationViewItem Content="收录信息"
                                Tag="header-db"
                                Click="OnNavItemClick">
                                <ui:NavigationViewItem.Icon>
                                    <ui:SymbolIcon Symbol="Table24"/>
                                </ui:NavigationViewItem.Icon>
                            </ui:NavigationViewItem>
                        </ui:NavigationView.MenuItems>

                        <ui:NavigationView.FooterMenuItems>
                            <!-- 更新提示项：有可用更新时显示，点击弹出更新弹窗 -->
                            <ui:NavigationViewItem x:Name="UpdateNavItem" Tag="update"
                                Click="OnUpdateItemClick"
                                Visibility="Collapsed">
                                <ui:NavigationViewItem.Icon>
                                    <ui:SymbolIcon Symbol="ArrowUp16" Foreground="#FF3B30"/>
                                </ui:NavigationViewItem.Icon>
                                <ui:NavigationViewItem.Content>
                                    <ui:TextBlock Text="更新" Foreground="#FF3B30"/>
                                </ui:NavigationViewItem.Content>
                            </ui:NavigationViewItem>

                            <ui:NavigationViewItem Tag="settings"
                                Click="OnNavItemClick">
                                <ui:NavigationViewItem.Icon>
                                    <ui:SymbolIcon Symbol="Settings24"/>
                                </ui:NavigationViewItem.Icon>
                                <ui:NavigationViewItem.Content>
                                    <ui:TextBlock Text="设置"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </ui:NavigationViewItem.Content>
                            </ui:NavigationViewItem>
                        </ui:NavigationView.FooterMenuItems>
                    </ui:NavigationView>
                </Grid>
            </Border>

            <!-- 右侧内容区 -->
            <Border Grid.Column="1" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                <ContentControl Content="{Binding ActiveTabContent}"/>
            </Border>

            <!-- 弹窗覆盖层 — 提示/确认/错误弹窗 -->
            <Grid x:Name="DialogOverlay" Visibility="Collapsed"
                  Grid.ColumnSpan="2" Panel.ZIndex="1001">
                <!-- 遮罩层 -->
                <Grid Background="#88000000" />
                <!-- 弹窗卡片 -->
                <Border x:Name="DialogCard"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        MinWidth="320" MaxWidth="500"
                        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="6"
                                          Opacity="0.30" Color="Black"/>
                    </Border.Effect>
                    <Grid Margin="24,20,24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- 标题行 -->
                            <RowDefinition Height="Auto"/>  <!-- 内容行 -->
                            <RowDefinition Height="Auto"/>  <!-- 输入行 -->
                            <RowDefinition Height="Auto"/>  <!-- 按钮行 -->
                        </Grid.RowDefinitions>

                        <!-- 标题 -->
                        <StackPanel x:Name="DialogHeader" Grid.Row="0"
                                    Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon x:Name="DialogIcon" FontSize="20"
                                           Margin="0,0,10,0"/>
                            <ui:TextBlock x:Name="DialogTitle" FontSize="16"
                                          FontWeight="SemiBold"
                                          VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 内容 -->
                        <ui:TextBlock x:Name="DialogMessage" Grid.Row="1"
                                      FontSize="14" TextWrapping="Wrap"
                                      Margin="0,4,0,16" Opacity="0.8"/>

                        <StackPanel Grid.Row="2" Margin="0,0,0,16">
                            <ui:TextBox x:Name="DialogInputBox"
                                        Visibility="Collapsed"
                                        Width="420"
                                        HorizontalAlignment="Stretch"
                                        Height="36" FontSize="13"
                                        common:FloatingTextPreview.IsEnabled="False"
                                        VerticalContentAlignment="Center"/>

                            <ui:TextBlock x:Name="DialogInputErrorText"
                                          Visibility="Collapsed"
                                          Width="420"
                                          HorizontalAlignment="Stretch"
                                          FontSize="12"
                                          Foreground="#C42B1C"
                                          TextWrapping="Wrap"
                                          Margin="0,6,0,0"/>
                        </StackPanel>

                        <!-- 按钮 -->
                        <StackPanel x:Name="DialogButtons" Grid.Row="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,4,0,0">
                            <ui:Button x:Name="DialogCancelBtn"
                                    Appearance="Secondary"
                                    MinWidth="90" Margin="0,0,10,0"
                                    Click="DialogOverlay_CancelClick"/>
                            <ui:Button x:Name="DialogPrimaryBtn"
                                    Appearance="Primary"
                                    MinWidth="90"
                                    Click="DialogOverlay_PrimaryClick"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- 进度条覆盖层 — 设置页操作时显示 -->
            <Grid Grid.ColumnSpan="2" Panel.ZIndex="1002"
                  Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVis}}">
                <!-- 半透明遮罩 -->
                <Rectangle Fill="#88000000"/>

                <!-- 居中卡片 -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        MinWidth="360" MaxWidth="420"
                        CornerRadius="16"
                        Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Padding="28,24">
                    <StackPanel>
                        <!-- 状态文字 -->
                        <ui:TextBlock Text="{Binding ProgressText}"
                                      FontSize="14" FontWeight="Medium"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Margin="0,0,0,16"/>

                        <!-- 进度条 -->
                        <ProgressBar Value="{Binding ProgressPercentage}"
                                     Minimum="0" Maximum="100"
                                     Height="6"
                                     Foreground="{DynamicResource AccentFillColorPrimaryBrush}"
                                     Background="{DynamicResource ControlFillColorDefaultBrush}"/>

                        <!-- 百分比文字 -->
                        <ui:TextBlock HorizontalAlignment="Right"
                                      FontSize="12"
                                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                      Margin="0,6,0,0">
                            <Run Text="{Binding ProgressPercentage, StringFormat={}{0:F0}}"/>
                            <Run Text="%"/>
                        </ui:TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 设置面板 — 居中覆盖层，仅 X 按钮关闭 -->
            <Grid x:Name="SettingsOverlay" Visibility="Collapsed"
                  Grid.ColumnSpan="2"
                  Background="#88000000" Panel.ZIndex="1000">
                <Border x:Name="SettingsCard" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="820" MinHeight="560" MaxHeight="720"
                        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                        CornerRadius="18"
                        BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="6"
                                          Opacity="0.30" Color="Black"/>
                    </Border.Effect>
                    <Grid x:Name="SettingsContentGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 标题栏 -->
                        <Grid Grid.Row="0" Margin="28,22,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings20" FontSize="20"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <ui:TextBlock Text="设置" FontSize="20" FontWeight="Bold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <ui:TextBlock Text="管理应用外观与偏好" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="2" Width="32" Height="32"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="0"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Click="SettingsOverlay_Close">
                                <ui:SymbolIcon Symbol="Dismiss20" FontSize="16"/>
                            </Button>
                        </Grid>

                        <!-- 分隔线 -->
                        <Rectangle Grid.Row="1" Height="1" Margin="28,18,28,0"
                                   Fill="{DynamicResource DividerStrokeColorDefaultBrush}"/>

                        <!-- 内容 -->
                        <views:SettingsView Grid.Row="2" x:Name="SettingsViewControl" Margin="0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 更新弹窗覆盖层 — 居中卡片，展示更新详情和下载进度 -->
            <!-- 点击遮罩层将下载放入后台 -->
            <Grid x:Name="UpdateOverlay" Visibility="Collapsed"
                  Grid.ColumnSpan="2"
                  Background="#88000000" Panel.ZIndex="1003"
                  MouseLeftButtonDown="UpdateOverlay_BackgroundClick">
                    <!-- 弹窗卡片（点击卡片内部不关闭弹窗） -->
                    <Border x:Name="UpdateOverlayCard"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Width="440"
                            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                            CornerRadius="16"
                            BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            MouseLeftButtonDown="UpdateOverlay_CardClick">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="6"
                                          Opacity="0.30" Color="Black"/>
                    </Border.Effect>
                    <Grid Margin="28,24,28,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 标题行：图标 + 标题 + 关闭按钮 -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="10" Width="40" Height="40"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                <ui:SymbolIcon Symbol="ArrowSync16" FontSize="20"
                                               Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <ui:TextBlock Text="发现新版本" FontSize="16" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <ui:TextBlock Text="{Binding CurrentVersion, StringFormat='当前版本 v{0}'}" FontSize="12"
                                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                              Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- 版本信息行 -->
                        <Grid Grid.Row="1" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="4" Padding="8,3"
                                    Background="{DynamicResource AccentFillColorDefaultBrush}">
                                <ui:TextBlock Text="{Binding NewVersion, StringFormat='v{0}'}" FontSize="12" FontWeight="SemiBold"
                                              Foreground="White"/>
                            </Border>

                            <ui:TextBlock Grid.Column="1"
                                          Text="{Binding FileSizeDisplay}"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>

                        <!-- 更新日志 -->
                        <Border x:Name="UpdateLogBorder" Grid.Row="2" CornerRadius="8" Padding="14,10"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                Margin="0,0,0,16"
                                MaxHeight="220">
                            <!-- ScrollViewer 会把子元素宽度约束到视口宽度（纵向测量给无限高），
                                 因此 ItemsControl 直接放入即可让内部 TextBlock 正确换行，
                                 无需再套一层 Grid 绑定 ViewportWidth（那会引入测量依赖）。
                                 CanContentScroll=False：按像素滚动，超 MaxHeight 时显示垂直滚动条。 -->
                            <ScrollViewer x:Name="UpdateLogScroller"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          HorizontalContentAlignment="Stretch"
                                          Padding="0,0,10,0">
                                <ItemsControl ItemsSource="{Binding Changelog}"
                                              HorizontalContentAlignment="Stretch">
                                    <!-- 关键：默认 ItemsControl 生成的 ContentPresenter 是
                                         HorizontalAlignment=Left，导致内部 Grid 只拿到"内容所需宽度"
                                         （等效无限宽），TextWrapping 失效。显式设为 Stretch 后，
                                         每个条目容器会撑满 ScrollViewer 宽度，Grid 的 * 列得到有限宽度，
                                         TextBlock 即可正确换行。 -->
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- 圆点标记（仅内容行显示，头部行隐藏） -->
                                                <Ellipse Grid.Column="0" Width="4" Height="4"
                                                         Fill="{DynamicResource AccentFillColorDefaultBrush}"
                                                         VerticalAlignment="Top" Margin="0,5,8,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <ui:TextBlock Grid.Column="1" Text="{Binding Text}"
                                                              FontSize="12"
                                                              TextWrapping="Wrap"
                                                              TextTrimming="None"
                                                              HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Center">
                                                    <ui:TextBlock.Style>
                                                        <Style TargetType="ui:TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    <Setter Property="FontSize" Value="13"/>
                                                                    <Setter Property="Margin" Value="0,6,0,2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:TextBlock.Style>
                                                </ui:TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <!-- 下载进度区域 -->
                        <StackPanel Grid.Row="3"
                                    Visibility="{Binding ShowProgressBar, Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,16">
                            <!-- 下载详情：网速 + 大小 + 剩余时间 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ui:TextBlock Grid.Column="0"
                                              Text="{Binding SpeedDisplay}"
                                              FontSize="12" FontWeight="SemiBold"
                                              Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                              VerticalAlignment="Center"/>

                                <ui:TextBlock Grid.Column="1"
                                              Text="{Binding SizeDisplay}"
                                              FontSize="12"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              VerticalAlignment="Center" Margin="12,0,0,0"/>

                                <ui:TextBlock Grid.Column="2"
                                              Text="{Binding EtaDisplay}"
                                              FontSize="12"
                                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                              VerticalAlignment="Center"/>
                            </Grid>

                            <!-- 进度条 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ProgressBar Grid.Column="0"
                                             Minimum="0" Maximum="100"
                                             Value="{Binding Progress}"
                                             Height="6"
                                             VerticalAlignment="Center"/>

                                <ui:TextBlock Grid.Column="1"
                                              Text="{Binding ProgressDisplay}"
                                              FontSize="12"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                              VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- 按钮行 -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <ui:Button Content="{Binding LeftButtonText}"
                                       Appearance="Secondary"
                                       Height="36" MinWidth="90" FontSize="13"
                                       Margin="0,0,10,0"
                                       Click="UpdateOverlay_LeftButtonClick"/>
                            <ui:Button Content="{Binding ActionButtonText}"
                                       Appearance="Primary"
                                       Height="36" MinWidth="110" FontSize="13"
                                       Click="UpdateOverlay_PrimaryClick"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
