<ui:FluentWindow x:Class="Quotix.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Quotix"
        xmlns:vm="clr-namespace:Quotix.ViewModels"
        xmlns:views="clr-namespace:Quotix.Views"
        Title="Quotix"
        Height="860" Width="1300"
        MinHeight="640" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="None"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate DataType="{x:Type vm:NewQuotationViewModel}">
            <views:NewQuotationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductDatabaseViewModel}">
            <views:ProductDatabaseView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HeaderDatabaseViewModel}">
            <views:HeaderDatabaseView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <ui:TitleBar Grid.Row="0"
                     x:Name="TitleBar" Height="30"
                     Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                     ShowMinimize="True"
                     ShowMaximize="True"
                     ShowClose="True">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                    <Image x:Name="TitleBarIconImage" Width="14" Height="14"
                           Stretch="Uniform" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Quotix" FontSize="12"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- 主布局：左侧导航 + 右侧内容 + 设置覆盖层 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航栏 -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 导航菜单 -->
                    <ui:NavigationView
                        Grid.Row="0"
                        x:Name="RootNavView"
                        PaneDisplayMode="Left"
                        IsPaneOpen="True"
                        OpenPaneLength="240"
                        CompactPaneLength="48"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleVisible="False"
                        Margin="0"
                        Background="Transparent">

                        <ui:NavigationView.PaneHeader>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Height="36" Width="36"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                        BorderThickness="0" Cursor="Hand"
                                        Padding="0"
                                        Click="TogglePane_Click">
                                    <Grid Width="18" Height="18">
                                        <ui:SymbolIcon x:Name="PaneToggleIcon"
                                                       FontSize="18"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Height="36" Width="36"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                        BorderThickness="0" Cursor="Hand"
                                        Padding="0"
                                        Click="ToggleTheme_Click">
                                    <Grid Width="18" Height="18">
                                        <ui:SymbolIcon x:Name="ThemeIcon" Symbol="WeatherMoon20" FontSize="18"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </ui:NavigationView.PaneHeader>

                        <ui:NavigationView.Resources>
                            <!-- 导航项默认前景色：适配深色/浅色模式 -->
                            <Style TargetType="ui:NavigationViewItem" BasedOn="{StaticResource {x:Type ui:NavigationViewItem}}">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </Style>
                        </ui:NavigationView.Resources>

                        <ui:NavigationView.MenuItems>
                            <ui:NavigationViewItem Content="新建报价"
                                Tag="new-quotation"
                                Click="OnNavItemClick">
                                <ui:NavigationViewItem.Icon>
                                    <ui:SymbolIcon Symbol="DocumentAdd24"/>
                                </ui:NavigationViewItem.Icon>
                            </ui:NavigationViewItem>
                            <ui:NavigationViewItem Content="报价历史"
                                Tag="history"
                                Click="OnNavItemClick">
                                <ui:NavigationViewItem.Icon>
                                    <ui:SymbolIcon Symbol="History24"/>
                                </ui:NavigationViewItem.Icon>
                            </ui:NavigationViewItem>
                            <ui:NavigationViewItem Content="产品列表"
                                Tag="product-db"
                                Click="OnNavItemClick">
                                <ui:NavigationViewItem.Icon>
                                    <ui:SymbolIcon Symbol="Box24"/>
                                </ui:NavigationViewItem.Icon>
                            </ui:NavigationViewItem>
                            <ui:NavigationViewItem Content="收录信息"
                                Tag="header-db"
                                Click="OnNavItemClick">
                                <ui:NavigationViewItem.Icon>
                                    <ui:SymbolIcon Symbol="Table24"/>
                                </ui:NavigationViewItem.Icon>
                            </ui:NavigationViewItem>
                        </ui:NavigationView.MenuItems>

                        <ui:NavigationView.FooterMenuItems>
                            <ui:NavigationViewItem Content="设置"
                                Tag="settings"
                                Click="OnNavItemClick">
                                <ui:NavigationViewItem.Icon>
                                    <Grid>
                                        <ui:SymbolIcon Symbol="Settings24"/>
                                        <!-- 更新红点（后台代码控制） -->
                                        <Border x:Name="UpdateRedDot"
                                                Visibility="Collapsed"
                                                Background="Red"
                                                CornerRadius="6"
                                                Width="12" Height="12"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="4,-4,-4,0"/>
                                    </Grid>
                                </ui:NavigationViewItem.Icon>
                            </ui:NavigationViewItem>
                        </ui:NavigationView.FooterMenuItems>
                    </ui:NavigationView>
                </Grid>
            </Border>

            <!-- 右侧内容区 -->
            <Border Grid.Column="1" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                <ContentControl Content="{Binding ActiveTabContent}"/>
            </Border>

            <!-- 弹窗覆盖层 — 提示/确认/错误弹窗 -->
            <Grid x:Name="DialogOverlay" Visibility="Collapsed"
                  Grid.ColumnSpan="2" Panel.ZIndex="1001">
                <!-- 遮罩层 -->
                <Grid Background="#88000000" />
                <!-- 弹窗卡片 -->
                <Border x:Name="DialogCard"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        MinWidth="320" MaxWidth="500"
                        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="6"
                                          Opacity="0.30" Color="Black"/>
                    </Border.Effect>
                    <Grid Margin="24,20,24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- 标题行 -->
                            <RowDefinition Height="Auto"/>  <!-- 内容行 -->
                            <RowDefinition Height="Auto"/>  <!-- 按钮行 -->
                        </Grid.RowDefinitions>

                        <!-- 标题 -->
                        <StackPanel x:Name="DialogHeader" Grid.Row="0"
                                    Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon x:Name="DialogIcon" FontSize="20"
                                           Margin="0,0,10,0"/>
                            <ui:TextBlock x:Name="DialogTitle" FontSize="16"
                                          FontWeight="SemiBold"
                                          VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 内容 -->
                        <ui:TextBlock x:Name="DialogMessage" Grid.Row="1"
                                      FontSize="14" TextWrapping="Wrap"
                                      Margin="0,4,0,16" Opacity="0.8"/>

                        <!-- 按钮 -->
                        <StackPanel x:Name="DialogButtons" Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,4,0,0">
                            <ui:Button x:Name="DialogCancelBtn"
                                    Appearance="Secondary"
                                    MinWidth="90" Margin="0,0,10,0"
                                    Click="DialogOverlay_CancelClick"/>
                            <ui:Button x:Name="DialogPrimaryBtn"
                                    Appearance="Primary"
                                    MinWidth="90"
                                    Click="DialogOverlay_PrimaryClick"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- 密码输入弹窗 — 居中内嵌卡片 -->
            <Grid x:Name="PasswordOverlay" Visibility="Collapsed"
                  Grid.ColumnSpan="2" Panel.ZIndex="1002">
                <Grid Background="#88000000" />
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        MinWidth="360" MaxWidth="460"
                        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="6"
                                          Opacity="0.30" Color="Black"/>
                    </Border.Effect>
                    <Grid Margin="24,20,24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- 标题 -->
                            <RowDefinition Height="Auto"/>  <!-- 消息 -->
                            <RowDefinition Height="Auto"/>  <!-- 密码框 -->
                            <RowDefinition Height="Auto"/>  <!-- 错误提示 -->
                            <RowDefinition Height="Auto"/>  <!-- 按钮 -->
                        </Grid.RowDefinitions>

                        <!-- 标题行 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:SymbolIcon x:Name="PwdDialogIcon" Symbol="LockClosed12"
                                           FontSize="20" Margin="0,0,10,0"/>
                            <ui:TextBlock x:Name="PwdDialogTitle" FontSize="16"
                                          FontWeight="SemiBold"
                                          VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 消息 -->
                        <ui:TextBlock x:Name="PwdDialogMessage" Grid.Row="1"
                                      FontSize="13" TextWrapping="Wrap"
                                      Margin="0,2,0,14" Opacity="0.8"/>

                        <!-- 密码输入框 -->
                        <Border Grid.Row="2"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                Margin="0,0,0,4">
                            <Grid Height="34">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 隐藏模式 -->
                                <PasswordBox Grid.Column="0"
                                             x:Name="PwdBox"
                                             FontSize="14"
                                             VerticalAlignment="Stretch"
                                             VerticalContentAlignment="Center"
                                             Padding="8,0"
                                             BorderThickness="0"
                                             PasswordChar="●"
                                             Background="Transparent"
                                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                             KeyDown="PwdBox_KeyDown"/>

                                <!-- 显示模式 -->
                                <TextBox Grid.Column="0"
                                         x:Name="PwdRevealBox"
                                         FontSize="14"
                                         VerticalAlignment="Stretch"
                                         VerticalContentAlignment="Center"
                                         Padding="8,0"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                         Visibility="Collapsed"
                                         KeyDown="PwdBox_KeyDown"/>

                                <!-- 眼睛切换按钮 -->
                                <ui:Button Grid.Column="1"
                                           x:Name="PwdToggleBtn"
                                           Width="36"
                                           VerticalAlignment="Stretch"
                                           Padding="0" Margin="0"
                                           Appearance="Transparent"
                                           Click="PwdToggle_Click">
                                    <ui:SymbolIcon x:Name="PwdToggleIcon"
                                                   Symbol="Eye16"
                                                   FontSize="16"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </ui:Button>
                            </Grid>
                        </Border>

                        <!-- 错误提示 -->
                        <ui:TextBlock x:Name="PwdErrorText" Grid.Row="3"
                                      FontSize="12" TextWrapping="Wrap"
                                      Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                      Visibility="Collapsed"
                                      Margin="0,4,0,0"/>

                        <!-- 按钮 -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,14,0,0">
                            <ui:Button x:Name="PwdCancelBtn"
                                    Content="取消"
                                    Appearance="Secondary"
                                    MinWidth="90" Margin="0,0,10,0"
                                    Click="PasswordOverlay_CancelClick"/>
                            <ui:Button x:Name="PwdConfirmBtn"
                                    Content="确定"
                                    Appearance="Primary"
                                    MinWidth="90"
                                    Click="PasswordOverlay_ConfirmClick"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- 进度条覆盖层 — 设置页操作时显示 -->
            <Grid Grid.ColumnSpan="2" Panel.ZIndex="1002"
                  Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVis}}">
                <!-- 半透明遮罩 -->
                <Rectangle Fill="#88000000"/>

                <!-- 居中卡片 -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        MinWidth="360" MaxWidth="420"
                        CornerRadius="16"
                        Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Padding="28,24">
                    <StackPanel>
                        <!-- 状态文字 -->
                        <ui:TextBlock Text="{Binding ProgressText}"
                                      FontSize="14" FontWeight="Medium"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Margin="0,0,0,16"/>

                        <!-- 进度条 -->
                        <ProgressBar Value="{Binding ProgressPercentage}"
                                     Minimum="0" Maximum="100"
                                     Height="6"
                                     Foreground="{DynamicResource AccentFillColorPrimaryBrush}"
                                     Background="{DynamicResource ControlFillColorDefaultBrush}"/>

                        <!-- 百分比文字 -->
                        <ui:TextBlock HorizontalAlignment="Right"
                                      FontSize="12"
                                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                      Margin="0,6,0,0">
                            <Run Text="{Binding ProgressPercentage, StringFormat={}{0:F0}}"/>
                            <Run Text="%"/>
                        </ui:TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 设置面板 — 居中覆盖层，仅 X 按钮关闭 -->
            <Grid x:Name="SettingsOverlay" Visibility="Collapsed"
                  Grid.ColumnSpan="2"
                  Background="#88000000" Panel.ZIndex="1000">
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="520" MaxHeight="680"
                        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                        CornerRadius="16"
                        BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="6"
                                          Opacity="0.30" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 标题栏 -->
                        <Grid Grid.Row="0" Margin="28,22,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings20" FontSize="20"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <ui:TextBlock Text="设置" FontSize="20" FontWeight="Bold"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <ui:TextBlock Text="管理应用外观与偏好" FontSize="12"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="2" Width="32" Height="32"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="0"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Click="SettingsOverlay_Close">
                                <ui:SymbolIcon Symbol="Dismiss20" FontSize="16"/>
                            </Button>
                        </Grid>

                        <!-- 分隔线 -->
                        <Rectangle Grid.Row="1" Height="1" Margin="28,18,28,0"
                                   Fill="{DynamicResource DividerStrokeColorDefaultBrush}"/>

                        <!-- 内容 -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <views:SettingsView x:Name="SettingsViewControl" Margin="28,20,28,28"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
